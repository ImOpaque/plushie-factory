# Copy this file to `.env` on each machine, then adjust paths if needed.
# Restart `npm run dev` after changes. Only `VITE_*` vars are exposed to the browser.

# Optional: your own plush model under `public/`
# VITE_TEDDY_GLTF_URL=/models/teddy.glb

VITE_TEDDY_GLTF_URL=/models/bear_basic.glb

# Machine stage model (default /models/machine.glb). Set to 0 for built-in procedural machine only.
# VITE_MACHINE_GLTF_URL=/models/machine.glb
# VITE_MACHINE_GLTF_URL=0
